# examples/fleet.env
#
# orchestrator 용 환경변수 파일 예시.
# /etc/fleet/fleet.env 로 복사 후 실제 값으로 채우고
# examples/fleet.service 의 EnvironmentFile= 지시자가 읽는다.
#
# systemd 규칙: 빈 값/주석은 무시되며, "KEY=VALUE" 형식만 인식.

# ─── 필수 ─────────────────────────────────────────────────────────────
# Postgres 연결 문자열.
DATABASE_URL=postgres://fleet:CHANGE_ME@db.internal:5432/fleet

# ─── HTTP API ─────────────────────────────────────────────────────────
# 0.0.0.0 으로 바인딩하면 외부 노출. Cloudflare Access 가 앞에 없다면
# 127.0.0.1 로 두고 ssh -L 로 포워딩하는 것을 권장.
FLEET_HTTP_BIND=127.0.0.1:8081

# HTTP API 에 대한 bearer 인증 토큰들 (쉼표 구분).
# 워커 등록 시에도 동일한 토큰 중 하나가 필요.
# `openssl rand -hex 32` 로 생성.
FLEET_API_TOKENS=fleet-CHANGE_ME_TOKEN_1

# ─── 대시보드 ─────────────────────────────────────────────────────────
FLEET_DASHBOARD_BIND=127.0.0.1:8082

# ─── 헬스체크 ─────────────────────────────────────────────────────────
FLEET_HEALTH_INTERVAL=15
FLEET_HEALTH_MISSED=3

# ─── Cloudflare Zero Trust (옵션) ─────────────────────────────────────
# Cloudflare Access Application Audience tag. 설정하면 모든 HTTP 요청의
# CF-JWT 를 검증한다. 미설정 시 Cloudflare Access 검증 생략.
# FLEET_CF_AUDIENCE=abcdef0123456789abcdef0123456789

# ─── mTLS (Phase 8.5; 옵션) ───────────────────────────────────────────
# 사설 CA 로 워커들의 TLS 트래픽을 보호.
# `fleet mtls init-ca && fleet mtls issue-server` 로 발급.
# FLEET_MTLS_CA=/etc/fleet/ca.pem
# FLEET_MTLS_CERT=/etc/fleet/server.pem
# FLEET_MTLS_KEY=/etc/fleet/server.key

# ─── 로깅 ─────────────────────────────────────────────────────────────
RUST_LOG=fleet=info,fleet_store=info,sqlx=warn,tower_http=info
